# Google Maps API Key
# Get this from: Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase Configuration
# Get these values from: Supabase Dashboard → Settings → API
# Project URL: The URL of your Supabase project (e.g., https://xxxxx.supabase.co)
# Anon Key: The public anonymous key (safe to expose in client-side code)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Google Sign-In Configuration
# Get this from: Google Cloud Console → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application type for Expo)
# This is used for Google OAuth authentication in the mobile app
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
